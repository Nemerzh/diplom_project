        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Available і unavailable",
      "description": "**available** — готові; **unavailable** — очікують / проблемні (аналог «не все running»).",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "targets": [
        {
          "expr": "max by (namespace, deployment) (kube_deployment_status_replicas_available{namespace=~\"$k8s_namespace\", deployment=~\"backend|frontend|simulator|postgres\"})",
          "legendFormat": "{{deployment}} — available"
        },
        {
          "expr": "max by (namespace, deployment) (kube_deployment_status_replicas_unavailable{namespace=~\"$k8s_namespace\", deployment=~\"backend|frontend|simulator|postgres\"})",
          "legendFormat": "{{deployment}} — unavailable"
        }
      ]
    }
  ],
